{
  "name": "dsplab",
  "private": true,
  "version": "1.0.0",
  "description": "A professional-grade Web-based DSP IDE and Prototyping Studio",
  "author": "syso (DatanoiseTV)",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "electron-dist/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build-main": "esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=electron-dist/main.cjs --external:electron && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=electron-dist/preload.cjs --external:electron",
    "electron:dev": "npm run electron:build-main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron-dist/main.cjs\"",
    "electron:build": "npm run build && npm run electron:build-main && electron-builder",
    "electron:preview": "npm run build && npm run electron:build-main && electron electron-dist/main.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/prismjs": "^1.26.6",
    "framer-motion": "^12.35.2",
    "jszip": "^3.10.1",
    "ltrim": "^1.0.1",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.27.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vult": "0.4.15",
    "webmidi": "^3.1.14"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.4",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3",
    "@eslint/js": "^9.39.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tar": "^7.5.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
